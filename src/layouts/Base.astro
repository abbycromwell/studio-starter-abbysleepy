---
import '../styles/tokens.css';
import '../styles/global.css';
import { workCategories } from '../data/work.js';

const { title = 'Abby Cromwell — Portfolio', description = 'Portfolio of an emerging designer.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Main">
        <a href="/" class="nav-name">Abby Cromwell</a>
        <ul class="nav-links">
          {workCategories.map((category) => (
            <li><a href={`/work/${category.slug}/`}>{category.title}</a></li>
          ))}
          <li><a href="/about/">About</a></li>
        </ul>
      </nav>
    </header>
    <main id="main" class="page">
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; 2026 Abby Cromwell</p>
    </footer>
  </body>
</html>
