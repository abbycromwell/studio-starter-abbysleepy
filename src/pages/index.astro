---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import boogerSelfPortrait from '../assets/home/booger-self-portrait.webp';
import tripleApple from '../assets/home/triple-apple-watercolor.webp';
import figureDrawingAlfred from '../assets/work/drawing/figure-drawing-alfred.webp';
import landscapeAbstract from '../assets/home/landscape-abstract.webp';
import watercolorCockroach from '../assets/home/watercolor-cockroach.webp';

const selectedWork = [
  {
    src: boogerSelfPortrait,
    alt: 'Self-portrait of a dark-haired figure surrounded by insects',
  },
  {
    src: tripleApple,
    alt: 'Reclining figure among three red apples and broken objects',
  },
  {
    src: figureDrawingAlfred,
    alt: 'Standing figure holding a long length of fabric',
  },
  {
    src: landscapeAbstract,
    alt: 'Four-panel blue and yellow abstract landscape study',
  },
  {
    src: watercolorCockroach,
    alt: 'Purple-haired figure leaning away from oversized cockroaches',
  },
];
---

<Base>
  <section class="hero">
    <h1>Abby Cromwell</h1>
    <a href="/work/">See my work</a>
  </section>

  <section aria-labelledby="selected-work">
    <h2 id="selected-work">Selected work</h2>
    <ul class="home-gallery">
      {selectedWork.map((item, index) => (
        <li>
          <Image
            src={item.src}
            alt={item.alt}
            loading={index === 0 ? 'eager' : 'lazy'}
          />
        </li>
      ))}
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding: var(--space-2xl) 0;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    margin: 0 0 var(--space-md);
  }

  h2 {
    font-size: var(--text-xl);
    margin: 0 0 var(--space-lg);
  }

  .home-gallery {
    list-style: none;
    display: grid;
    gap: var(--space-xl);
    margin: 0;
    padding: 0;
  }

  .home-gallery img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
</style>
