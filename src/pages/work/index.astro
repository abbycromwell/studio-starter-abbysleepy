---
import Base from '../../layouts/Base.astro';
---

<Base title="Work — Your Name">
  <h1>Work</h1>
  <p class="intro">Selected projects. Each one tells a story: what you made, why, and what you learned.</p>
  <ul class="work-list">
    <li>
      <a href="/work/first-project/">First Project</a>
      <p>One line about this project. Add more projects to this list as you go.</p>
    </li>
  </ul>
</Base>

<style>
  h1 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-sm);
  }

  .intro {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-xl);
  }

  .work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
  }

  .work-list a {
    font-size: var(--text-lg);
  }

  .work-list p {
    margin: var(--space-2xs) 0 0;
    color: var(--color-text-secondary);
  }
</style>
