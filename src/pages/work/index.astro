---
import Base from '../../layouts/Base.astro';
import { workCategories } from '../../data/work.js';
---

<Base title="Work — Abby Cromwell">
  <h1>Work</h1>
  <p class="intro">Original work across mediums.</p>
  <ul class="work-list">
    {workCategories.map((category) => (
      <li>
        <a href={`/work/${category.slug}/`} class="work-link">{category.title}</a>
        <p>{category.items.length} {category.items.length === 1 ? 'work' : 'works'}</p>
      </li>
    ))}
  </ul>
</Base>

<style>
  h1 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-sm);
  }

  .intro {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-xl);
  }

  .work-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
  }

  .work-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
  }

  .work-link {
    font-size: var(--text-lg);
  }

  .work-list p {
    margin: 0;
    color: var(--color-text-secondary);
  }
</style>
