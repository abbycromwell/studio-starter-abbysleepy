---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { workCategories } from '../../data/work.js';

export function getStaticPaths() {
  return workCategories.map((category) => ({
    params: { category: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
---

<Base title={`${category.title} — Abby Cromwell`}>
  <ul class="category-gallery">
    {category.items.map((item, index) => (
      <li>
        <figure>
          <Image
            src={item.src}
            alt={item.alt}
            loading={index === 0 ? 'eager' : 'lazy'}
          />
        </figure>
      </li>
    ))}
  </ul>
</Base>

<style>
  .category-gallery {
    list-style: none;
    display: grid;
    gap: var(--space-xl);
    margin: 0;
    padding: 0;
  }

  figure {
    margin: 0;
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius-sm);
  }
</style>
