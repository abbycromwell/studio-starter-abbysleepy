---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import abbyPortrait from '../assets/about/abby-cromwell-portrait.webp';
---

<Base title="About — Abby Cromwell">
  <Image
    src={abbyPortrait}
    alt="Abby Cromwell wearing a dark suit and hat while holding a white disc over her face"
    loading="eager"
  />
  <p class="bio">I am Abby Cromwell from California. I love art, all things Japanese, and my dog Yuki.</p>
  <p>
    <a href="https://docs.google.com/document/d/1kTXfgbIZkrj786EC5Tr3nq8RbgaTDvpwrt6qRgbXYmw/edit?usp=sharing">
      View my resume
    </a>
  </p>
</Base>

<style>
  .bio {
    max-width: calc(var(--max-width-page) / 2);
    line-height: var(--leading-loose);
    margin-top: var(--space-lg);
  }

  img {
    display: block;
    width: 100%;
    max-width: calc(var(--max-width-page) / 2);
    height: auto;
    border-radius: var(--radius-sm);
  }
</style>
